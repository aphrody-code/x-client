{
  "name": "@your-org/x",
  "version": "1.0.0",
  "private": true,
  "description": "Headless X (Twitter) client in pure TypeScript for Bun. Built on top of Bun Web APIs (fetch) and Bun APIs (Bun.file). Replicates the entire x-client Rust functionality.",
  "keywords": [
    "aphrody",
    "bun",
    "x",
    "twitter",
    "client",
    "graphql",
    "headless"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "fmt": "oxfmt src",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
