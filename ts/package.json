{
  "name": "@aphrody-code/x",
  "version": "1.0.2",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Headless X (Twitter) client in pure TypeScript for Bun. Built on top of Bun Web APIs (fetch) and Bun APIs (Bun.file). Replicates the entire x-client Rust functionality.",
  "keywords": [
    "aphrody",
    "bun",
    "x",
    "twitter",
    "client",
    "graphql",
    "headless"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "fmt": "oxfmt src",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
